// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ============================================
// Enums
// ============================================

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Environment {
  PROD
  STAGING
  DEV
}


enum ErrorType {
  TIMEOUT
  DNS_ERROR
  CONNECTION_ERROR
  STATUS_MISMATCH
}

enum IncidentType {
  FAILURE
  LATENCY
}

enum IncidentStatus {
  OPEN
  CLOSED
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom app fields
  role          Role     @default(USER)
  plan          Plan     @default(FREE)

  sessions      Session[]
  accounts      Account[]
  monitors      Monitor[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ============================================
// App models
// ============================================

model Monitor {
  id             String        @id @default(cuid())
  userId         String
  name           String
  url            String
  intervalSec    Int
  expectedStatus Int           @default(200)
  timeoutMs      Int           @default(5000)
  environment    Environment
  isActive       Boolean       @default(true)
  slug           String        @unique
  createdAt      DateTime      @default(now())
  nextCheckAt    DateTime      @default(now())
  lastCheckedAt  DateTime?

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkResults   CheckResult[]
  incidents      Incident[]

  @@index([userId])
  @@index([isActive])
  @@index([nextCheckAt, isActive])
}

model CheckResult {
  id              String      @id @default(cuid())
  monitorId       String
  checkedAt       DateTime    @default(now())
  statusCode      Int?
  latencyMs       Int?
  errorType       ErrorType?
  responseSnippet String?     @db.VarChar(500)

  monitor         Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
}

model Incident {
  id               String         @id @default(cuid())
  monitorId        String
  type             IncidentType
  status           IncidentStatus @default(OPEN)
  startedAt        DateTime       @default(now())
  endedAt          DateTime?
  aiTriageText     String?
  aiGeneratedAt    DateTime? 
  aiModel          String?
  incidentSnapshot Json?

  monitor          Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, status])
  @@index([monitorId, startedAt])
}


