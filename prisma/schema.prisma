// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ============================================
// Enums
// ============================================

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Environment {
  PROD
  STAGING
  DEV
}


enum ErrorType {
  TIMEOUT
  DNS_ERROR
  CONNECTION_ERROR
  STATUS_MISMATCH
}

enum IncidentType {
  FAILURE
  LATENCY
}

enum IncidentStatus {
  OPEN
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — null for OAuth users
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  monitors      Monitor[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// App models
// ============================================

model Monitor {
  id             String        @id @default(cuid())
  userId         String
  name           String
  url            String
  intervalSec    Int
  expectedStatus Int           @default(200)
  timeoutMs      Int           @default(5000)
  environment    Environment
  isActive       Boolean       @default(true)
  slug           String        @unique
  createdAt      DateTime      @default(now())
  nextCheckAt    DateTime      @default(now())
  lastCheckedAt  DateTime?

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkResults   CheckResult[]
  incidents      Incident[]

  @@index([userId])
  @@index([isActive])
  @@index([nextCheckAt, isActive])
}

model CheckResult {
  id              String      @id @default(cuid())
  monitorId       String
  checkedAt       DateTime    @default(now())
  statusCode      Int?
  latencyMs       Int?
  errorType       ErrorType?
  responseSnippet String?     @db.VarChar(500)

  monitor         Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, checkedAt])
}

model Incident {
  id               String         @id @default(cuid())
  monitorId        String
  type             IncidentType
  status           IncidentStatus @default(OPEN)
  startedAt        DateTime       @default(now())
  endedAt          DateTime?
  aiTriageText     String?
  aiGeneratedAt    DateTime? 
  aiModel          String?
  incidentSnapshot Json?

  monitor          Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId, status])
  @@index([monitorId, startedAt])
}


